# === Supabase ===
REACT_APP_SUPABASE_URL=https://gfjppwfgvsdyxocottvn.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# === Supabase (server-side, used by Vercel functions) ===
SUPABASE_URL=https://gfjppwfgvsdyxocottvn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === Spotify OAuth ===
# Create an app at https://developer.spotify.com/dashboard
# Add redirect URI: http://localhost:3000/api/spotify/callback (dev)
#                   https://your-domain.vercel.app/api/spotify/callback (prod)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# === Anthropic (Claude AI for match computation) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Ticketmaster Discovery API (Events) ===
# Get a free key at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
